package compose:dynlink@0.1.0;

/// A guest that dynamically links (dlopens) other components at runtime.
///
/// The native host implements `linker` on top of its embedded wasm
/// engine, exactly as `compose:host` implements its surface. Everything
/// else the guest needs comes through standard WASI.
world dynlink-guest {
  import linker;
}

/// A component that can be dynamically loaded by others.
///
/// Such a component exports the uniform message endpoint and is
/// addressed by content digest (or registry id). It may itself import
/// `linker` to load further components.
world dynlink-provider {
  export endpoint;
}

/// A consumer component whose single `endpoint` import is satisfied at
/// exec time by a host-resolved provider (flavor A: late-bound plan
/// imports). The host implements `endpoint` by forwarding to the bound
/// provider, which it runs in a separate store.
world endpoint-consumer {
  import endpoint;
}

/// A dynlink provider whose plugged extension is a STREAMING dot-command:
/// it emits output through the `sqlite:extension/cli-stdout` host import
/// rather than returning it in `invoke-result.text`. `wac plug` cannot
/// wire that import to the provider's own cli-stdout export (the cycle
/// provider-provides-cli-stdout AND consumes-dot-command), so the import
/// is left dangling and the HOST supplies it — exactly as the bespoke
/// CLI loader owns the streams. This world is the host's bindgen target:
/// it exports `endpoint` (the dynlink surface) and imports the CLI stream
/// interfaces the host implements and captures.
world dynlink-provider-cli {
  export endpoint;
  import sqlite:extension/cli-stdout@1.0.0;
  import sqlite:extension/cli-stderr@1.0.0;
  import sqlite:extension/cli-state@1.0.0;
}
